# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp Cloud API (Meta) — optional; sends order confirmation to the customer
# Create an app at https://developers.facebook.com/ → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: approved template name (required for first message if customer never wrote you)
# Template body params expected: {{1}}=order id, {{2}}=restaurant, {{3}}=total
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=es
